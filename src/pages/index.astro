---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import BentoGrid from '../components/BentoGrid.astro';
import TheExperience from '../components/TheExperience.astro';
import Schedule from '../components/Schedule.astro';
import Pricing from '../components/Pricing.astro';
import TestimonialsSlider from '../components/TestimonialsSlider.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import ReservasSection from '../components/ReservasSection.astro';
---

<Layout>
  <Hero />

  <main>
    <BentoGrid />
    <TheExperience />
    <Schedule />
    <Pricing />
    <TestimonialsSlider />
    <InstagramFeed />
    <ReservasSection />
  </main>

  <!-- Footer minimalista -->
  <footer class="py-12 px-6 bg-[#2D2D2D] text-[#F9F6F2]" id="contacto">
    <div class="max-w-4xl mx-auto text-center">
      <p class="font-serif text-2xl text-[#F9F6F2] mb-2">ZENITH Yoga & Spa</p>
      <p class="text-[#D4A373] text-sm mb-4">Calle de la Paz, 12 — 28001 Madrid</p>
      <p class="text-[#F9F6F2]/70 text-sm">
        <a href="mailto:hola@zenithyogaspa.com" class="hover:text-[#D4A373] transition-colors">hola@zenithyogaspa.com</a>
        · <a href="tel:+34915758767" class="hover:text-[#D4A373] transition-colors">+34 915 75 87 67</a>
      </p>
      <p class="text-[#F9F6F2]/50 text-xs mt-8">© {new Date().getFullYear()} ZENITH Yoga & Spa</p>
    </div>
  </footer>

  <!-- Scroll reveal: fade-in y reveal al hacer scroll -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { rootMargin: '0px 0px -60px 0px', threshold: 0.08 }
    );

    document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));
  </script>
</Layout>
