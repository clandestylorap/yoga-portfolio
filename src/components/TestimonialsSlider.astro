---
import ScrollReveal from './ScrollReveal.astro';

const testimonials = [
  {
    quote: 'ZENITH no es un gimnasio. Es el lugar donde por primera vez entendí qué significa practicar con presencia.',
    author: 'Carmen L.',
    role: 'Monthly',
  },
  {
    quote: 'Las clases de Vinyasa con Marcos son pura fluidez. El espacio y la luz hacen que cada mañana sea especial.',
    author: 'Pablo M.',
    role: 'Unlimited',
  },
  {
    quote: 'La meditación sonora me cambió. Salgo renovada. El equipo y el ambiente son de otro nivel.',
    author: 'Laura S.',
    role: 'Drop-in',
  },
];
---

<section class="py-20 md:py-28 px-6 bg-white overflow-hidden" id="testimonios" aria-labelledby="testimonials-title">
  <div class="max-w-4xl mx-auto">
    <ScrollReveal type="fade" class="text-center mb-14">
      <h2 id="testimonials-title" class="font-serif text-4xl md:text-5xl text-[#2D2D2D] mb-4">Testimonios</h2>
      <p class="text-[#2D2D2D]/70 font-light">Lo que dicen quienes practican yoga en ZENITH.</p>
    </ScrollReveal>

    <!-- Slider: citas grandes en cursiva -->
    <ScrollReveal type="fade">
      <div class="relative">
        <div id="testimonial-track" class="flex transition-transform duration-500 ease-out">
          {testimonials.map((t, i) => (
            <div
              class="testimonial-slide min-w-full px-4 md:px-8 py-8"
              data-index={i}
              aria-hidden={i !== 0}
            >
              <blockquote class="text-center">
                <p class="font-serif text-2xl md:text-3xl lg:text-4xl text-[#2D2D2D] italic leading-relaxed mb-8">
                  "{t.quote}"
                </p>
                <footer>
                  <cite class="not-italic font-medium text-[#2D2D2D]">{t.author}</cite>
                  <span class="text-[#D4A373] text-sm ml-2">— {t.role}</span>
                </footer>
              </blockquote>
            </div>
          ))}
        </div>

        <!-- Controles -->
        <div class="flex justify-center gap-4 mt-8" role="tablist" aria-label="Navegar testimonios">
          {testimonials.map((_, i) => (
            <button
              type="button"
              class="w-2.5 h-2.5 rounded-full transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-[#D4A373] focus:ring-offset-2 testimonial-dot"
              data-index={i}
              aria-label={`Testimonio ${i + 1}`}
              aria-selected={i === 0}
            ></button>
          ))}
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>

<style>
  .testimonial-dot {
    background-color: #e8e6e2;
  }
  .testimonial-dot[aria-selected='true'],
  .testimonial-dot:hover {
    background-color: #D4A373;
    transform: scale(1.2);
  }
</style>

<script>
  const track = document.getElementById('testimonial-track');
  const dots = document.querySelectorAll('.testimonial-dot');
  const slides = document.querySelectorAll('.testimonial-slide');
  let current = 0;
  const total = slides.length;

  function goTo(index: number) {
    current = ((index % total) + total) % total;
    if (track) track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => {
      d.setAttribute('aria-selected', i === current ? 'true' : 'false');
    });
    slides.forEach((s, i) => {
      s.setAttribute('aria-hidden', i !== current ? 'true' : 'false');
    });
  }

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => goTo(i));
  });

  // Auto-advance cada 5s
  setInterval(() => goTo(current + 1), 5000);
</script>
