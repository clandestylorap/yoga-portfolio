---
import { Image } from 'astro:assets';
import ScrollReveal from './ScrollReveal.astro';

// Mockup: imágenes optimizadas con astro:assets (Image)
const feedImages = [
  { src: '/public/images/instagram_1.jpg', alt: 'Práctica de yoga en el estudio', width: 400, height: 400 },
  { src: '/public/images/instagram_2.jpg', alt: 'Sesión de Hatha', width: 400, height: 400 },
  { src: '/public/images/instagram_3.jpg', alt: 'Espacio ZENITH', width: 400, height: 400 },
  { src: '/public/images/instagram_4.jpg', alt: 'Clase en grupo', width: 400, height: 400 },
  { src: '/public/images/instagram_5.jpg', alt: 'Meditación', width: 400, height: 400 },
];
---

<section class="py-16 md:py-24 px-6 bg-[#F9F6F2]" id="community" aria-labelledby="feed-title">
  <div class="max-w-5xl mx-auto">
    <ScrollReveal type="fade" class="text-center mb-12">
      <h2 id="feed-title" class="font-serif text-3xl md:text-4xl text-[#2D2D2D] mb-2">Síguenos</h2>
      <p class="text-[#2D2D2D]/70 font-light text-sm">@zenithyogaspa — clases, retiros y comunidad.</p>
    </ScrollReveal>

    <ScrollReveal type="fade">
      <div class="flex flex-wrap justify-center gap-3 md:gap-4">
        {feedImages.map((item) => (
          <a
            href="#"
            class="block w-[calc(50%-0.375rem)] sm:w-[calc(33.333%-0.5rem)] md:w-36 lg:w-40 aspect-square rounded-xl overflow-hidden bg-[#e8e6e2] shadow-md hover:shadow-lg hover:scale-[1.03] transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-[#D4A373] focus:ring-offset-2 focus:ring-offset-[#F9F6F2]"
            aria-label={item.alt}
          >
            <Image
              src={item.src}
              alt={item.alt}
              width={item.width}
              height={item.height}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </a>
        ))}
      </div>
    </ScrollReveal>
  </div>
</section>
