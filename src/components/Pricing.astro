---
import ScrollReveal from './ScrollReveal.astro';

const plans = [
  {
    id: 'dropin',
    name: 'Drop-in',
    price: '22',
    period: 'clase suelta',
    description: 'Ideal para probar una clase o venir de forma ocasional.',
    features: ['1 clase', 'Acceso a vestuario', 'Sin compromiso'],
    featured: false,
  },
  {
    id: 'monthly',
    name: 'Monthly',
    price: '89',
    period: 'al mes',
    description: 'Para una práctica regular. Incluye todas las disciplinas.',
    features: ['8 clases al mes', 'Todas las disciplinas', 'Prioridad de reserva', 'Vestuario y duchas'],
    featured: true,
  },
  {
    id: 'unlimited',
    name: 'Unlimited',
    price: '129',
    period: 'al mes',
    description: 'Libertad total. Clases de yoga ilimitadas y sesiones de meditación sonora.',
    features: ['Clases ilimitadas', 'Meditación sonora incluida', 'Acceso prioritario', 'Invitación a eventos'],
    featured: false,
  },
];
---

<section class="py-20 md:py-28 px-6 bg-[#F9F6F2]" id="pricing" aria-labelledby="pricing-title">
  <div class="max-w-5xl mx-auto">
    <ScrollReveal type="fade" class="text-center mb-16">
      <h2 id="pricing-title" class="font-serif text-4xl md:text-5xl text-[#2D2D2D] mb-4">Planes</h2>
      <p class="text-[#2D2D2D]/70 font-light max-w-lg mx-auto">Elige el plan que mejor se adapte a tu práctica.</p>
    </ScrollReveal>

    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      {plans.map((plan) => (
        <ScrollReveal type="fade" class={plan.featured ? 'md:-mt-2 md:mb-2' : ''}>
          <article
            class={`relative rounded-2xl p-8 h-full flex flex-col transition duration-300 ${
              plan.featured
                ? 'bg-[#2D2D2D] text-[#F9F6F2] shadow-2xl ring-2 ring-[#D4A373] ring-offset-4 ring-offset-[#F9F6F2] shadow-[#D4A373]/20'
                : 'bg-white text-[#2D2D2D] shadow-lg border border-[#e8e6e2] hover:shadow-xl'
            }`}
          >
            {plan.featured && (
              <div class="absolute inset-0 rounded-2xl overflow-hidden pointer-events-none" aria-hidden="true">
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-32 bg-[#D4A373]/10 rounded-full blur-3xl"></div>
              </div>
            )}
            <div class="relative">
              <h3 class="font-serif text-2xl mb-1">{plan.name}</h3>
              <p class="text-sm opacity-80 mb-6">{plan.description}</p>
              <div class="flex items-baseline gap-1 mb-6">
                <span class={`font-serif text-4xl ${plan.featured ? 'text-[#F9F6F2]' : 'text-[#2D2D2D]'}`}>{plan.price}€</span>
                <span class="text-sm opacity-70">/ {plan.period}</span>
              </div>
              <ul class="space-y-3 mb-8">
                {plan.features.map((f) => (
                  <li class="flex items-center gap-2 text-sm">
                    <span class={`w-1.5 h-1.5 rounded-full ${plan.featured ? 'bg-[#D4A373]' : 'bg-[#D4A373]'}`}></span>
                    {f}
                  </li>
                ))}
              </ul>
              <a
                href="#reservas"
                class={`block w-full py-3.5 rounded-xl text-center font-medium text-sm transition ${
                  plan.featured
                    ? 'bg-[#D4A373] text-[#2D2D2D] hover:bg-[#e8c9a8]'
                    : 'bg-[#2D2D2D] text-[#F9F6F2] hover:bg-[#4a4a4a]'
                }`}
              >
                Reservar
              </a>
            </div>
          </article>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
